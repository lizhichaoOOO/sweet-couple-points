/* pages/shared-goal/shared-goal.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD1DC 0%, #FFE4EC 50%, #FFD9C2 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.title {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  margin-bottom: 48rpx;
  text-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.2);
}

.goal-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-bottom: 60rpx;
}

.goal-card {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4EC 100%);
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  gap: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.12);
}

.goal-illu {
  width: 200rpx;
  height: 200rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FFD1DC, #FFB6CE);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.goal-emoji {
  font-size: 120rpx;
}

.goal-main {
  flex: 1;
}

.goal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.goal-points {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.goal-contrib {
  font-size: 22rpx;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.progress {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFB07C 0%, #FF6B8A 100%);
  border-radius: 6rpx;
}

.add-btn {
  background: linear-gradient(135deg, #FF8FA8 0%, #FF6B8A 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 60rpx;
  padding: 32rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.3);
  border: none;
  margin: 0 auto;
  width: 80%;
}

.add-btn::after {
  border: none;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
}

.achieved-tag {
  background: #4ECDC4;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  vertical-align: middle;
}
