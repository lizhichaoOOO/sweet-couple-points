/* pages/profile/profile.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFDFB8 0%, #FFE4EC 50%, #FFF5F7 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

/* 合照 */
.photo-card {
  text-align: center;
  margin-bottom: 40rpx;
}

.photo {
  width: 480rpx;
  height: 280rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  margin-bottom: 24rpx;
}

.names-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.name-divider {
  width: 40rpx;
}

.days-chip {
  background: linear-gradient(135deg, #FF6B8A, #FFB6CE);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-weight: 500;
  margin-left: 16rpx;
}

/* 统计卡 */
.stats-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.08);
}

.stats-title {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
  margin-bottom: 16rpx;
}

.stat-unit {
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 4rpx;
}

.stat-icon {
  font-size: 40rpx;
}

/* 菜单 */
.menu-card {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 32rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
}

.menu-item {
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 2rpx solid rgba(45, 27, 46, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
}

.menu-arrow {
  color: var(--color-text-muted);
  font-size: 40rpx;
  line-height: 1;
}

/* 退出登录 */
.logout-btn {
  background: linear-gradient(135deg, #FFB6CE 0%, #FF8FA8 100%);
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 60rpx;
  padding: 32rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.3);
  border: none;
}

.logout-btn::after {
  border: none;
}
