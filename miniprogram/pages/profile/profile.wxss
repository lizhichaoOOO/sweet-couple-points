/* pages/profile/profile.wxss */
.user-card {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #eee;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.menu {
  margin-bottom: 24rpx;
  padding: 0;
}

.menu-item {
  padding: 32rpx;
  border-bottom: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: var(--color-text-muted);
}
