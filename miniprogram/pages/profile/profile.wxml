<!--pages/profile/profile.wxml-->
<view class="page">
  <!-- 合照区 -->
  <view class="photo-card">
    <image
      wx:if="{{photoUrl}}"
      class="photo"
      src="{{photoUrl}}"
      mode="aspectFill"
    />
    <view wx:else class="photo photo-placeholder">
      <text class="photo-emoji">👩‍❤️‍👨</text>
    </view>
    <view class="names-row">
      <text class="name">{{myName}}</text>
      <text class="name-divider"></text>
      <text class="name">{{partnerName}}</text>
      <view class="days-chip">在一起{{daysTogether}}天</view>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-card">
    <view class="stats-title">统计</view>
    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-label">累计获得</view>
        <view class="stat-value">{{stats.totalPoints}}<text class="stat-unit">积分</text></view>
        <view class="stat-icon">💗</view>
      </view>
      <view class="stat-item">
        <view class="stat-label">完成任务</view>
        <view class="stat-value">{{stats.completedTasks}}<text class="stat-unit">项</text></view>
        <view class="stat-icon">☑️</view>
      </view>
      <view class="stat-item">
        <view class="stat-label">兑换奖励</view>
        <view class="stat-value">{{stats.redeemedRewards}}<text class="stat-unit">份</text></view>
        <view class="stat-icon">🎁</view>
      </view>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-card">
    <view
      wx:for="{{menus}}"
      wx:key="label"
      class="menu-item"
      data-url="{{item.url}}"
      bindtap="tapMenu"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-label">{{item.label}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>
</view>
