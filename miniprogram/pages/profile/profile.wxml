<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="card user-card">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-default.png'}}" />
    <view class="user-info">
      <view class="nickname">{{userInfo.nickName || '未登录'}}</view>
      <view class="text-muted">{{bound ? '已绑定' : '未绑定'}}</view>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="goBind">
      <text>情侣绑定</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAnniversary">
      <text>纪念日</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMood">
      <text>心情打卡</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMessages">
      <text>留言板</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item">
      <text>任务管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>奖励管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>关于</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
