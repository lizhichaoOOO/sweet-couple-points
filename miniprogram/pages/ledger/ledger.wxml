<!--pages/ledger/ledger.wxml-->
<view class="page">
  <view class="tabs">
    <view
      class="tab {{filter === 'all' ? 'active' : ''}}"
      data-filter="all"
      bindtap="switchFilter"
    >全部</view>
    <view
      class="tab {{filter === 'add' ? 'active' : ''}}"
      data-filter="add"
      bindtap="switchFilter"
    >加分</view>
    <view
      class="tab {{filter === 'deduct' ? 'active' : ''}}"
      data-filter="deduct"
      bindtap="switchFilter"
    >扣分</view>
  </view>

  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索原因" value="{{keyword}}" bindinput="onInput" />
  </view>

  <view wx:if="{{!records.length}}" class="empty-tip text-muted">
    {{keyword ? '没有找到匹配的记录' : '暂无记录'}}
  </view>

  <view class="records">
    <view wx:for="{{records}}" wx:key="_id" class="record">
      <view class="rec-main">
        <view class="rec-title">{{item.title}}</view>
        <view class="rec-time">{{item.time}}</view>
      </view>
      <view class="rec-delta {{item.type}}">
        <view class="delta-num">{{item.delta > 0 ? '+' : ''}}{{item.delta}}</view>
        <view class="delta-label">{{item.type === 'add' ? '积分增加' : '积分扣除'}}</view>
      </view>
    </view>
  </view>
</view>
