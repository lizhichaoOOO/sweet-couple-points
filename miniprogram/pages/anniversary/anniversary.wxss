/* pages/anniversary/anniversary.wxss */
.anniversary-item {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.anniversary-title {
  font-weight: 500;
  margin-bottom: 8rpx;
}

.anniversary-days {
  text-align: right;
}

.days-num {
  color: var(--color-primary);
  font-size: 40rpx;
  font-weight: 700;
}

.empty-tip {
  text-align: center;
  color: var(--color-text-muted);
  padding: 80rpx 0;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
}
