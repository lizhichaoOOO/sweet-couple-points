<!--pages/anniversary/anniversary.wxml-->
<view class="container">
  <view wx:if="{{list.length === 0}}" class="empty-tip">
    还没有纪念日，去添加吧
  </view>
  <view wx:for="{{list}}" wx:key="id" class="card anniversary-item">
    <view class="anniversary-info">
      <view class="anniversary-title">{{item.title}}</view>
      <view class="anniversary-date text-muted">{{item.date}}</view>
    </view>
    <view class="anniversary-days">
      <view class="days-num">{{item.daysText}}</view>
      <view class="text-muted">{{item.unit}}</view>
    </view>
  </view>
  <button class="btn-primary fab" bindtap="addAnniversary">+ 新增纪念日</button>
</view>
