<!--pages/bind/bind.wxml-->
<view class="page">
  <view class="sparkles">
    <text class="sparkle sp1">✦</text>
    <text class="sparkle sp2">✦</text>
    <text class="sparkle sp3">✦</text>
    <text class="sparkle sp4">✦</text>
  </view>

  <view class="title">欢迎来到情侣<view class="br"></view>积分小程序</view>

  <view class="couple-row">
    <view class="avatar-col">
      <view class="avatar-ring">
        <text class="ring-emoji">👧</text>
      </view>
      <view class="pill-btn" bindtap="copyCode">
        <view class="pill-label">分享邀请码</view>
        <view class="pill-code">{{myCode}}</view>
      </view>
    </view>

    <view class="hearts-mid">
      <text class="mid-heart h1">♥</text>
      <text class="mid-heart h2">♥</text>
      <text class="mid-heart h3">♥</text>
    </view>

    <view class="avatar-col">
      <view class="avatar-ring">
        <text class="ring-emoji">👦</text>
      </view>
      <view class="pill-btn" bindtap="scan">
        <view class="pill-label">扫码绑定</view>
      </view>
    </view>
  </view>

  <view class="manual-bind">
    <view class="manual-label">或输入对方邀请码</view>
    <view class="manual-row">
      <input
        class="manual-input"
        placeholder="6 位邀请码"
        placeholder-class="manual-ph"
        value="{{inputCode}}"
        bindinput="onInputCode"
        maxlength="10"
      />
      <button class="manual-btn" bindtap="confirmBind" loading="{{loading}}" disabled="{{loading}}">绑定</button>
    </view>
  </view>

  <view class="deco-hearts">
    <text class="deco h-lg">♥</text>
    <text class="deco h-sm">♥</text>
    <text class="deco h-md">♥</text>
  </view>
</view>
