/* pages/bind/bind.wxss */
.section-title {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
}

.my-code {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 16rpx;
  color: var(--color-primary);
  text-align: center;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
}

.code-input {
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
  font-size: 32rpx;
  letter-spacing: 8rpx;
}

.card {
  margin-bottom: 24rpx;
}

.tip {
  text-align: center;
  padding: 24rpx;
}
