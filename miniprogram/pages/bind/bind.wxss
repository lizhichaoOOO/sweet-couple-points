/* pages/bind/bind.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD1DC 0%, #FFE4EC 40%, #FFF5F7 100%);
  padding: 60rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.sparkles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.sparkle {
  position: absolute;
  color: #fff;
  font-size: 40rpx;
  opacity: 0.9;
}

.sp1 { top: 200rpx; left: 80rpx; }
.sp2 { top: 160rpx; right: 80rpx; font-size: 56rpx; }
.sp3 { top: 380rpx; right: 40rpx; }
.sp4 { bottom: 300rpx; left: 60rpx; font-size: 48rpx; }

.title {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
  margin-bottom: 120rpx;
  position: relative;
  z-index: 1;
}

.br {
  height: 8rpx;
}

.couple-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  position: relative;
  z-index: 1;
  margin-bottom: 80rpx;
}

.avatar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.avatar-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-primary);
  padding: 4rpx;
  background: linear-gradient(135deg, #FFD1DC, #FFE4EC);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-emoji {
  font-size: 120rpx;
  line-height: 1;
}

.pill-btn {
  background: #fff;
  border: 4rpx solid var(--color-primary);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  min-width: 240rpx;
}

.pill-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
}

.pill-code {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 4rpx;
  margin-top: 4rpx;
}

.hearts-mid {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding-top: 60rpx;
}

.mid-heart {
  color: #FFB6CE;
  font-size: 36rpx;
}

.mid-heart.h1 { font-size: 28rpx; }
.mid-heart.h2 { font-size: 44rpx; color: #FF8FA8; }
.mid-heart.h3 { font-size: 32rpx; }

.deco-hearts {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 100rpx;
  pointer-events: none;
}.deco {
  position: absolute;
  color: #FFB6CE;
  opacity: 0.7;
}

.h-lg { font-size: 96rpx; left: 40rpx; bottom: 0; color: #FFD1DC; }
.h-md { font-size: 72rpx; right: 80rpx; bottom: 40rpx; }
.h-sm { font-size: 48rpx; right: 160rpx; bottom: 160rpx; }

/* 手动输入 */
.manual-bind {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.08);
}

.manual-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-align: center;
  margin-bottom: 16rpx;
}

.manual-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.manual-input {
  flex: 1;
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  text-align: center;
}

.manual-ph {
  color: var(--color-text-muted);
  letter-spacing: 0;
}

.manual-btn {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 0 36rpx;
  line-height: 72rpx;
  height: 72rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 138, 0.25);
}

.manual-btn::after {
  border: none;
}
