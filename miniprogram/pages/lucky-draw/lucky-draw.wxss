/* pages/lucky-draw/lucky-draw.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFC9A3 0%, #FFB6CE 50%, #FFD1DC 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
  text-align: center;
}

.head {
  margin-bottom: 32rpx;
}

.head-subtitle {
  font-size: 22rpx;
  color: var(--color-text);
  opacity: 0.7;
  display: block;
  margin-bottom: 8rpx;
}

.head-title {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--color-text);
  text-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.3);
}

/* 盲盒区 */
.box-wrap {
  position: relative;
  margin-bottom: 40rpx;
  padding: 40rpx 0;
}

.wheel {
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #FFE4A0 0%, #FFB07C 60%, #FF8F3F 100%);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 143, 63, 0.4), inset 0 -20rpx 40rpx rgba(0, 0, 0, 0.1);
  border: 12rpx solid #FFF5E6;
  transition: transform 0.6s ease-out;
}

.wheel.spinning {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.points-line {
  font-size: 26rpx;
  color: var(--color-text);
  margin: 24rpx 0;
  font-weight: 500;
}

.gift-box {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gift-emoji {
  font-size: 240rpx;
  filter: drop-shadow(0 12rpx 24rpx rgba(255, 107, 138, 0.4));
}

.sparkle-deco {
  position: absolute;
  color: #fff;
  font-size: 32rpx;
}

.s1 { top: 20rpx; left: 80rpx; font-size: 40rpx; }
.s2 { top: 40rpx; right: 100rpx; }
.s3 { bottom: 80rpx; left: 60rpx; }

/* 抽奖按钮 */
.draw-btn {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 80rpx;
  padding: 32rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.4);
  border: none;
  width: 80%;
  margin: 0 auto 40rpx;
}

.draw-btn::after {
  border: none;
}

/* 卡片小预览 */
.card-row {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 40rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 40rpx;
  display: flex;
  justify-content: space-around;
}

.mini-card {
  width: 80rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.c1 { color: #FF6B8A; }
.c2 { color: #2D1B2E; }
.c3 { color: #FF6B8A; }
.c4 { color: #2D1B2E; }

.pool-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.pool-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.pool-card {
  border-radius: 32rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
}

.stars {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.pool-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.pool-rarity {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
}
