<!--pages/tasks/tasks.wxml-->
<view class="page">
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-pill {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>

  <view class="task-list">
    <view wx:if="{{!tasks.length}}" class="empty-tip text-muted">
      {{activeTab === 'custom' ? '暂无自定义任务，点右下角 + 新建一个' : '暂无任务'}}
    </view>
    <view
      wx:for="{{tasks}}"
      wx:key="_id"
      class="task-card {{item.done ? 'task-done' : ''}}"
      data-task="{{item}}"
      bindtap="completeTask"
      bindlongpress="longPressTask"
    >
      <view class="icon-wrap">
        <text class="icon">{{item.icon}}</text>
      </view>
      <view class="task-title">{{item.title}}</view>
      <view wx:if="{{!item.done}}" class="points-badge">+{{item.points}}</view>
      <view wx:else class="check-wrap done">
        <text class="check">✓</text>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'custom'}}" class="fab" bindtap="addCustom">+</view>
</view>
