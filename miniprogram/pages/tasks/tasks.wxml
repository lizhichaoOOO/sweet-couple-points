<!--pages/tasks/tasks.wxml-->
<view class="page">
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-pill {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>

  <view class="task-list">
    <view wx:if="{{tasks[activeTab].length === 0}}" class="empty-tip text-muted">
      暂无任务，去添加一个吧
    </view>
    <view
      wx:for="{{tasks[activeTab]}}"
      wx:key="id"
      class="task-card"
    >
      <view class="icon-wrap">
        <text class="icon">{{item.icon}}</text>
      </view>
      <view class="task-title">{{item.title}}</view>
      <view class="task-points" wx:if="{{item.points.length}}">
        <view wx:for="{{item.points}}" wx:for-item="p" wx:key="*this" class="points-badge">+{{p}}</view>
      </view>
      <view wx:else class="check-wrap {{item.done ? 'done' : ''}}" data-id="{{item.id}}" bindtap="toggleTask">
        <text class="check">✓</text>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="addCustom">+</view>
</view>
