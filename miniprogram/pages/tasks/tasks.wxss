/* pages/tasks/tasks.wxss */
.page {
  min-height: 100vh;
  background: #FFF9E8;
  padding: 40rpx 32rpx 220rpx;
  box-sizing: border-box;
}

.tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.tab-pill {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 40rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 138, 0.1);
  text-align: center;
}

.tab-pill.active {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 138, 0.3);
}

.tab-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  white-space: pre-line;
  line-height: 1.3;
}

.tab-pill.active .tab-label {
  color: #fff;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.task-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.12);
}

.task-card.task-done {
  opacity: 0.55;
}

.task-card.task-done .task-title {
  text-decoration: line-through;
}

.icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD1DC, #FFF5F7);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon {
  font-size: 64rpx;
}

.task-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.task-points {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.points-badge {
  color: var(--color-primary);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.1;
}

.check-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-wrap.done {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.check-wrap .check {
  color: transparent;
  font-weight: 700;
}

.check-wrap.done .check {
  color: #fff;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
}

.fab {
  position: fixed;
  right: 48rpx;
  bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  color: #fff;
  font-size: 64rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.4);
}
