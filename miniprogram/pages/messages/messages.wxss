/* pages/messages/messages.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F4D9B8 0%, #E8C89A 40%, #D4AE74 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.title {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 32rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.board {
  position: relative;
  padding: 40rpx 0;
  min-height: 900rpx;
}

/* 装饰信封 */
.envelope {
  position: absolute;
  font-size: 96rpx;
  opacity: 0.6;
}

.e1 { top: 20rpx; left: 20rpx; }
.e2 { top: 160rpx; left: 40rpx; transform: rotate(-15deg); }

/* 图钉 */
.pin {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #FFC55C;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.p1 { top: 240rpx; left: 50%; transform: translateX(-50%); }
.p2 { top: 420rpx; left: 38%; }
.p3 { top: 600rpx; left: 55%; }

/* 信件卡片 */
.letters {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 0 40rpx 0 120rpx;
}

.letter-card {
  background: #FFF8EC;
  padding: 24rpx 28rpx;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  max-width: 440rpx;
}

.tilt-0 { transform: rotate(-1deg); }
.tilt-1 { transform: rotate(1.5deg); margin-left: 80rpx; }
.tilt-2 { transform: rotate(-0.5deg); }

.letter-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.letter-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD1DC, #FFB6CE);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
}

.letter-date {
  font-size: 20rpx;
  color: #8B7355;
}

.letter-body {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.letter-foot {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.heart-icon {
  color: #FF6B8A;
  font-size: 24rpx;
}

.likes {
  font-size: 22rpx;
  color: #8B7355;
}

/* 右侧贴纸 */
.sticker-col {
  position: absolute;
  right: 24rpx;
  top: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  align-items: center;
}

.sticker {
  font-size: 48rpx;
}

.write-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFF8EC;
  padding: 16rpx 12rpx;
  border-radius: 24rpx;
  margin-top: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.pen {
  font-size: 36rpx;
}

.write-label {
  font-size: 22rpx;
  color: var(--color-text);
  font-weight: 600;
  margin-top: 4rpx;
}

/* 发送按钮 */
.send-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 40rpx;
  padding: 0 24rpx;
}

.send-input {
  flex: 1;
  background: #FFF8EC;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 107, 138, 0.15);
}

.send-btn {
  width: 180rpx;
  background: linear-gradient(135deg, #FFB6CE 0%, #FF8FA8 100%);
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 60rpx;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.3);
  border: none;
  line-height: 1.3;
}

.send-btn::after {
  border: none;
}
