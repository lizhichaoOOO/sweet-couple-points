<!--pages/messages/messages.wxml-->
<view class="page">
  <view class="title">给你的情书</view>

  <view class="board">
    <!-- 左上角信封装饰 -->
    <view class="envelope e1">✉️</view>
    <view class="envelope e2">✉️</view>
    <view class="pin p1"></view>
    <view class="pin p2"></view>
    <view class="pin p3"></view>

    <!-- 信件卡片 -->
    <view wx:if="{{!letters.length}}" class="empty-tip text-muted">
      还没有情书，给 TA 写一封吧 →
    </view>

    <view class="letters">
      <view
        wx:for="{{letters}}"
        wx:key="_id"
        class="letter-card {{'tilt-' + (index % 3)}}"
        data-letter="{{item}}"
        bindlongpress="longPressLetter"
      >
        <view class="letter-head">
          <view class="letter-avatar">{{item.mine ? '🧑' : '💕'}}</view>
          <text class="letter-date">{{item.date}}</text>
        </view>
        <view class="letter-body">{{item.content}}</view>
        <view class="letter-foot" data-id="{{item._id}}" catchtap="likeLetter">
          <text class="heart-icon">♥</text>
          <text class="likes">{{item.likes}}</text>
        </view>
      </view>
    </view>

    <!-- 右侧贴纸 -->
    <view class="sticker-col">
      <text wx:for="{{stickers}}" wx:key="*this" class="sticker">{{item}}</text>
      <view class="write-pill" bindtap="writeNew">
        <text class="pen">✏️</text>
        <text class="write-label">写新情书</text>
      </view>
    </view>
  </view>

  <view class="send-row">
    <input
      class="send-input"
      placeholder="快速留句话"
      value="{{input}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="send"
    />
    <button class="send-btn" bindtap="send">发送</button>
  </view>
</view>
