/* pages/timeline/timeline.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE4EC 0%, #FFF5F7 100%);
  padding: 40rpx 24rpx 80rpx;
  box-sizing: border-box;
}

.page-title {
  text-align: center;
  margin-bottom: 40rpx;
  font-size: 60rpx;
}

.timeline {
  position: relative;
}

.center-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: repeating-linear-gradient(
    to bottom,
    var(--color-primary) 0,
    var(--color-primary) 12rpx,
    transparent 12rpx,
    transparent 24rpx
  );
  transform: translateX(-50%);
}

.row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
}

.left-card,
.right-card {
  flex: 1;
  background: linear-gradient(135deg, #FFE4EC, #FFB6CE);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 138, 0.15);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.left-card {
  margin-right: 24rpx;
}

.right-card {
  margin-left: 24rpx;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
}

.left-icon {
  font-size: 56rpx;
}

.left-meta {
  flex: 1;
}

.time {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
}

.date {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.right-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.right-delta {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--color-primary);
  transform: translate(-50%, -50%);
  box-shadow: 0 0 0 6rpx rgba(255, 107, 138, 0.2);
  z-index: 1;
}

.empty-tip {
  text-align: center;
  padding: 160rpx 0;
}
