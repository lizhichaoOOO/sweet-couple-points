/* pages/timeline/timeline.wxss */
.empty-tip {
  text-align: center;
  color: var(--color-text-muted);
  padding: 80rpx 0;
}

.record {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-left: 24rpx;
  position: relative;
}

.record-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 32rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.record-dot.plus {
  background: var(--color-primary);
}

.record-dot.minus {
  background: var(--color-text-muted);
}

.record-content {
  flex: 1;
}

.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.record-actor {
  font-weight: 500;
}

.record-delta {
  font-weight: 600;
}

.record-delta.plus {
  color: var(--color-primary);
}

.record-delta.minus {
  color: var(--color-text-muted);
}

.record-reason {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}
