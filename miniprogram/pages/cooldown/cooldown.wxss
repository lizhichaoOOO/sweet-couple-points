/* pages/cooldown/cooldown.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #D8DBF5 0%, #C5D4F5 40%, #FFD1DC 100%);
  padding: 40rpx 32rpx 40rpx;
  box-sizing: border-box;
  text-align: center;
  position: relative;
}

/* 徽章 */
.badge {
  display: inline-block;
  background: #fff;
  border: 4rpx dashed #FFB6CE;
  color: #FF6B8A;
  font-size: 26rpx;
  font-weight: 700;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  transform: rotate(-8deg);
  position: absolute;
  top: 100rpx;
  left: 40rpx;
  z-index: 2;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 138, 0.15);
}

.badge .sp {
  height: 2rpx;
}

.title {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin: 120rpx 0 40rpx;
  text-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.3);
  line-height: 1.2;
}

.title .tsp {
  height: 4rpx;
}

/* 内容布局 */
.content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 580rpx;
  margin-bottom: 40rpx;
}

/* 两侧头像 */
.side-avatar {
  position: absolute;
  top: 60rpx;
  width: 160rpx;
  z-index: 1;
}

.side-avatar.left {
  left: 0;
}

.side-avatar.right {
  right: 0;
}

.side-img {
  width: 280rpx;
  height: 380rpx;
  border-radius: 32rpx;
}

.side-placeholder {
  background: linear-gradient(135deg, #FFE4EC, #FFD1DC);
  display: flex;
  align-items: center;
  justify-content: center;
}

.side-emoji {
  font-size: 160rpx;
}

.side-avatar.left .side-img {
  transform: translateX(-60rpx);
}

.side-avatar.right .side-img {
  transform: translateX(60rpx);
}

.side-status {
  background: #fff;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: inline-block;
}

/* 计时器圆环 */
.timer-ring {
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0%, #FFF5F7 80%);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 138, 0.25), inset 0 0 0 8rpx rgba(255, 107, 138, 0.3);
  z-index: 2;
}

.timer-marks {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.mark {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 24rpx;
  background: #FFB6CE;
  border-radius: 2rpx;
  transform-origin: 50% 220rpx;
}

.timer-pointer {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 32rpx;
  background: #FFB6CE;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 138, 0.3);
}

.timer-inner {
  text-align: center;
}

.timer-label {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.timer-num {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: -4rpx;
  font-variant-numeric: tabular-nums;
}

/* 按钮 */
.btn-row {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 40rpx;
}

.cd-btn {
  flex: 1;
  max-width: 320rpx;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 60rpx;
  padding: 28rpx 0;
  border: none;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.25);
}

.cd-btn::after {
  border: none;
}

.cd-btn.extend {
  background: linear-gradient(135deg, #FFB6CE 0%, #FF8FA8 100%);
}

.cd-btn.end {
  background: linear-gradient(135deg, #FFC9A3 0%, #FFB07C 100%);
}

/* 分页指示 */
.dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #B8B8B8;
  opacity: 0.4;
}

.dot.active {
  background: #FF6B8A;
  opacity: 1;
}

/* 没有活跃冷静期 */
.no-active {
  text-align: center;
  padding: 120rpx 32rpx;
}

.no-active-emoji {
  font-size: 160rpx;
  margin-bottom: 32rpx;
}

.no-active-text {
  font-size: 30rpx;
  color: var(--color-text-muted);
  margin-bottom: 48rpx;
}

.start-btn {
  margin: 0 auto;
  width: 80%;
}
