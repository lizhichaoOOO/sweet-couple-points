<!--pages/index/index.wxml-->
<view class="page">
  <block wx:if="{{!bound}}">
    <view class="empty-wrap">
      <view class="empty-title">还没有绑定 TA 哦</view>
      <view class="empty-desc text-muted">绑定后才能开始你们的积分故事</view>
      <button class="btn-primary" bindtap="goBind">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <!-- 情侣头像 + 爱心连接 -->
    <view class="couple-section">
      <view class="avatar-box left">
        <view class="avatar-circle">
          <image wx:if="{{myInfo.avatar}}" class="avatar-img" src="{{myInfo.avatar}}" mode="aspectFill" />
          <text wx:else class="avatar-emoji">👦</text>
        </view>
      </view>

      <view class="heart-line">
        <view class="heart small">♥</view>
        <view class="heart">♥</view>
        <view class="heart small">♥</view>
      </view>

      <view class="avatar-box right">
        <view class="avatar-circle">
          <image wx:if="{{partnerInfo.avatar}}" class="avatar-img" src="{{partnerInfo.avatar}}" mode="aspectFill" />
          <text wx:else class="avatar-emoji">👧</text>
        </view>
      </view>
    </view>

    <!-- 双方积分 -->
    <view class="points-section">
      <view class="points-col">
        <view class="points-num">{{myInfo.points}}<text class="points-unit">分</text></view>
      </view>
      <view class="points-col">
        <view class="points-num">{{partnerInfo.points}}<text class="points-unit">分</text></view>
      </view>
    </view>

    <view class="days-tag">在一起 {{daysTogether}} 天</view>

    <!-- 今日任务 -->
    <view class="task-list">
      <view
        wx:for="{{todayTasks}}"
        wx:key="id"
        class="task-pill {{item.done ? 'done' : ''}}"
        data-id="{{item.id}}"
        bindtap="toggleTask"
      >
        <view class="task-check">
          <text wx:if="{{item.done}}" class="check-icon">✓</text>
          <text wx:else class="check-icon-empty">○</text>
        </view>
        <text class="task-text">{{item.title}}</text>
      </view>
    </view>

    <!-- 底部加分/扣分 -->
    <view class="action-bar">
      <view class="action-half plus" bindtap="addPoints">加分</view>
      <view class="action-divider"></view>
      <view class="action-half minus" bindtap="deductPoints">扣分</view>
    </view>
  </block>
</view>
