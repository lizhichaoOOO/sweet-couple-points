/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD9C2 0%, #FFE4EC 40%, #FFF5F7 100%);
  padding: 40rpx 32rpx 180rpx;
  box-sizing: border-box;
}

.empty-wrap {
  padding: 200rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-desc {
  margin-bottom: 48rpx;
}

/* 情侣头像区 */
.couple-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx 0;
}

.avatar-box {
  flex: 0 0 auto;
}

.avatar-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD1DC, #FFF5F7);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.2);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

/* 爱心虚线 */
.heart-line {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.heart {
  color: #FF6B8A;
  font-size: 40rpx;
}

.heart.small {
  font-size: 28rpx;
  opacity: 0.7;
}

/* 双方积分 */
.points-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 40rpx 0 20rpx;
}

.points-col {
  flex: 1;
  text-align: center;
}

.points-num {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
}

.points-unit {
  font-size: 40rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.days-tag {
  text-align: center;
  color: var(--color-text-muted);
  font-size: 26rpx;
  margin-bottom: 48rpx;
}

/* 任务胶囊 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.task-pill {
  background: #fff;
  border-radius: 60rpx;
  padding: 28rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 138, 0.08);
}

.task-pill.done .task-text {
  text-decoration: line-through;
  color: var(--color-text-muted);
}

.task-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.task-pill.done .task-check {
  background: var(--color-primary);
  color: #fff;
}

.task-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.check-icon-empty {
  visibility: hidden;
}

/* 底部加分扣分条 */
.action-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 40rpx;
  display: flex;
  background: linear-gradient(135deg, #FFB6CE 0%, #FF8FA8 100%);
  border-radius: 80rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.3);
}

.action-half {
  flex: 1;
  text-align: center;
  padding: 36rpx 0;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.action-divider {
  width: 2rpx;
  background: rgba(255, 255, 255, 0.5);
  margin: 16rpx 0;
}
