/* pages/shop/shop.wxss */
.balance {
  text-align: center;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #FF6B9D, #FFB6CE);
  color: #fff;
}

.balance-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.balance-value {
  font-size: 64rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.shop-item {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-info {
  flex: 1;
}

.item-title {
  font-weight: 500;
  margin-bottom: 8rpx;
}

.item-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.item-actions {
  text-align: right;
}

.item-price {
  color: var(--color-primary);
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.btn-small {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
}

.empty-tip {
  text-align: center;
  color: var(--color-text-muted);
  padding: 80rpx 0;
}
