/* pages/shop/shop.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD9C2 0%, #FFE4EC 50%, #FFF0F3 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

/* Hero 推荐区 */
.hero-card {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
  gap: 32rpx;
}

.hero-img {
  width: 260rpx;
  height: 260rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FFD1DC, #FFE4EC);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.15);
}

.hero-emoji {
  font-size: 160rpx;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.hero-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.hero-btn {
  display: inline-block;
  background: #fff;
  color: var(--color-text);
  padding: 20rpx 36rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.points-tag {
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 24rpx;
}

/* 2 列网格 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.grid-item {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx 24rpx 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.1);
  text-align: center;
}

.item-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFF5F7, #FFE4EC);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.item-emoji {
  font-size: 120rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.item-price-pill {
  display: inline-block;
  background: #fff;
  border: 2rpx solid var(--color-primary-soft);
  color: var(--color-text);
  font-weight: 600;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
}

/* 自定义奖励按钮 */
.custom-btn {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 60rpx;
  padding: 32rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.3);
  border: none;
  width: 100%;
}

.custom-btn::after {
  border: none;
}
