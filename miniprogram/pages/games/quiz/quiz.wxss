/* pages/games/quiz/quiz.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD9C2 0%, #FFE4EC 40%, #FFF0F3 100%);
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.loading {
  text-align: center;
  color: var(--color-text-muted);
  padding: 240rpx 0;
}

.section {
  display: flex;
  flex-direction: column;
}

/* === idle === */
.idle-hero {
  text-align: center;
  padding: 80rpx 0 60rpx;
}

.hero-emoji {
  font-size: 140rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  white-space: pre-line;
}

.last-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.12);
}

.last-title {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}

.last-score {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.last-total {
  font-size: 36rpx;
  color: var(--color-text-muted);
}

.last-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.last-reward {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #4ECDC4;
  font-weight: 600;
}

.start-btn {
  width: 80%;
  margin: 16rpx auto 0;
}

/* === answering === */
.progress-bar {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B8A, #FF8FA8);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 24rpx;
}

.q-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.14);
  margin-bottom: 32rpx;
}

.q-num {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.q-text {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 32rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  background: #FFF5F7;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.option-active {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFD1DC 100%);
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.2);
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid var(--color-primary-soft);
}

.option-active .option-letter {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
}

.nav-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.nav-btn {
  flex: 1;
  background: #fff;
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 20rpx 0;
  border: 2rpx solid var(--color-primary-soft);
  line-height: 1;
}

.nav-btn::after {
  border: none;
}

.nav-btn[disabled] {
  color: var(--color-text-muted);
  border-color: var(--color-border);
}

.nav-btn.submit {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.3);
}

.nav-btn.submit[disabled] {
  background: #F5C5D1;
  color: #fff;
  box-shadow: none;
}

.dots {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx 0 24rpx;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid var(--color-border);
}

.dot-done {
  background: var(--color-primary-soft);
  border-color: var(--color-primary-soft);
}

.dot-current {
  background: var(--color-primary);
  border-color: var(--color-primary);
  transform: scale(1.25);
}

.cancel-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  text-decoration: underline;
  margin-top: 8rpx;
}

/* === waiting === */
.waiting {
  text-align: center;
  padding: 120rpx 32rpx;
}

.waiting-emoji {
  font-size: 160rpx;
  margin-bottom: 32rpx;
  animation: bounce 1.2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.waiting-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.waiting-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  white-space: pre-line;
  margin-bottom: 48rpx;
}

.refresh-btn {
  width: 60%;
  margin: 0 auto 24rpx;
}

/* === result === */
.result {
  padding-top: 32rpx;
}

.score-ring {
  width: 360rpx;
  height: 360rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0%, #FFE4EC 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 138, 0.22),
              inset 0 0 0 8rpx rgba(255, 107, 138, 0.3);
}

.score-num {
  font-size: 144rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.score-total {
  font-size: 40rpx;
  color: var(--color-text-muted);
  margin-top: -8rpx;
}

.score-label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
  margin-top: 8rpx;
}

.score-comment {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.reward-banner {
  text-align: center;
  background: linear-gradient(135deg, #6FE3CC, #4ECDC4);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 20rpx 0;
  border-radius: 48rpx;
  margin: 0 40rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.3);
}

.detail-list {
  margin-bottom: 40rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.detail-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 8rpx solid transparent;
}

.detail-item.match {
  border-left-color: #4ECDC4;
}

.detail-item.miss {
  border-left-color: #FFB6CE;
}

.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.detail-flag {
  font-size: 22rpx;
  font-weight: 600;
}

.detail-item.match .detail-flag {
  color: #4ECDC4;
}

.detail-item.miss .detail-flag {
  color: var(--color-primary);
}

.detail-q {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.detail-ans {
  font-size: 24rpx;
  line-height: 1.6;
}

.ans-line {
  display: flex;
  gap: 8rpx;
}

.ans-who {
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.ans-opt {
  color: var(--color-text);
}

.again-btn {
  width: 80%;
  margin: 0 auto;
}
