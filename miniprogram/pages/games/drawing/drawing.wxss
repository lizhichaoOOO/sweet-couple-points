/* pages/games/drawing/drawing.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9E8 0%, #FFE4EC 50%, #FFF0F3 100%);
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}
.loading { text-align: center; color: var(--color-text-muted); padding: 240rpx 0; }

/* idle */
.hero { text-align: center; padding: 60rpx 0 40rpx; }
.hero-emoji { font-size: 120rpx; margin-bottom: 16rpx; }
.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}
.hero-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.7;
  white-space: pre-line;
}
.last-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.1);
}
.last-label {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}
.last-row { display: flex; gap: 8rpx; padding: 6rpx 0; }
.last-key { color: var(--color-text-muted); font-size: 24rpx; }
.last-val { color: var(--color-text); font-size: 26rpx; font-weight: 600; }
.last-flag {
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  margin-top: 12rpx;
  padding: 8rpx;
  border-radius: 16rpx;
}
.last-flag.ok { color: #4ECDC4; background: #E0F8F5; }
.last-flag.no { color: var(--color-primary); background: #FFE4EC; }

.start-btn { width: 80%; margin: 0 auto; }

.btn-primary {
  background: linear-gradient(135deg, #FFB07C 0%, #FF6B8A 100%);
  color: #fff; font-size: 32rpx; font-weight: 700;
  border-radius: 60rpx; padding: 28rpx 0; border: none;
  box-shadow: 0 10rpx 28rpx rgba(255, 143, 124, 0.3);
}
.btn-primary::after { border: none; }

/* draw-turn */
.word-card {
  background: linear-gradient(135deg, #FFF0D6, #FFE4EC);
  border-radius: 28rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 24rpx;
  border: 4rpx dashed #FFB07C;
}
.word-label { font-size: 22rpx; color: var(--color-text-muted); margin-bottom: 4rpx; }
.word-text {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 8rpx;
  margin-bottom: 6rpx;
}
.word-hint { font-size: 22rpx; color: var(--color-text-muted); }

.canvas-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}
.canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.canvas-tools {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.tool-btn {
  flex: 1;
  background: #fff;
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 20rpx 0;
  border: 2rpx solid var(--color-primary-soft);
  line-height: 1;
}
.tool-btn::after { border: none; }
.tool-btn.primary {
  background: linear-gradient(135deg, #FF6B8A, #FF8FA8);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 138, 0.3);
}

.cancel-link {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  text-decoration: underline;
  margin-top: 12rpx;
}

/* guess-turn */
.guess-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  margin: 16rpx 0 24rpx;
}
.drawing-view {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.drawing-img {
  width: 100%;
  height: 100%;
}

.guess-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.guess-input {
  flex: 1;
  background: #fff;
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 138, 0.08);
}
.guess-input-row .tool-btn {
  flex: 0 0 140rpx;
}

/* waiting */
.waiting { text-align: center; padding: 80rpx 32rpx; }
.waiting-emoji { font-size: 140rpx; animation: bounce 1.2s ease-in-out infinite; }
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
.waiting-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin: 24rpx 0 12rpx;
}
.waiting-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 32rpx;
}
.small-drawing {
  width: 60%;
  aspect-ratio: 1 / 1;
  margin: 0 auto 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}
.refresh-btn { width: 60%; margin: 0 auto; }

/* judge-turn */
.judge { text-align: center; padding: 40rpx 32rpx; }
.judge-title {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}
.judge-guess {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}
.judge-word {
  font-size: 28rpx;
  color: var(--color-primary);
  background: #FFE4EC;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  display: inline-block;
  margin-bottom: 24rpx;
}
.judge-tip { font-size: 24rpx; color: var(--color-text-muted); margin-bottom: 32rpx; }

.judge-buttons { display: flex; gap: 20rpx; }
.judge-btn {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 60rpx;
  padding: 28rpx 0;
  border: none;
  color: #fff;
  line-height: 1;
}
.judge-btn::after { border: none; }
.judge-btn.right {
  background: linear-gradient(135deg, #6FE3CC, #4ECDC4);
  box-shadow: 0 8rpx 20rpx rgba(78, 205, 196, 0.3);
}
.judge-btn.wrong {
  background: linear-gradient(135deg, #FFB6CE, #FF6B8A);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 138, 0.3);
}

/* result */
.outcome-banner {
  padding: 48rpx 32rpx;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
  color: #fff;
}
.outcome-banner.ok {
  background: linear-gradient(135deg, #6FE3CC, #4ECDC4);
}
.outcome-banner.no {
  background: linear-gradient(135deg, #FFB6CE, #FF6B8A);
}
.outcome-emoji { font-size: 140rpx; margin-bottom: 8rpx; }
.outcome-text { font-size: 44rpx; font-weight: 700; }
.outcome-reward { font-size: 26rpx; margin-top: 8rpx; opacity: 0.95; }

.reveal-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.1);
}
.reveal-row {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
}
.reveal-key { color: var(--color-text-muted); font-size: 26rpx; }
.reveal-val { color: var(--color-text); font-size: 28rpx; font-weight: 600; }

.result-drawing {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}
.again-btn { width: 80%; margin: 0 auto; }
