/* pages/games/truth-dare/truth-dare.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD9C2 0%, #FFE4EC 40%, #FFF0F3 100%);
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 难度切换 */
.level-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.level-pill {
  flex: 1;
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 138, 0.1);
}

.level-pill.active {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 138, 0.3);
}

.level-pill.spicy.active {
  background: linear-gradient(135deg, #FF7A3F 0%, #FF5C5C 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 90, 90, 0.35);
}

.lv-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.level-pill.active .lv-label {
  color: #fff;
}

.lv-count {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.level-pill.active .lv-count {
  color: rgba(255, 255, 255, 0.85);
}

/* 卡片 */
.card-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.card {
  width: 100%;
  min-height: 480rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 138, 0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  transition: transform 0.35s ease, opacity 0.35s ease;
  box-sizing: border-box;
}

.card.flipping {
  transform: rotateY(90deg) scale(0.95);
  opacity: 0.4;
}

.card.card-showing {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F7 100%);
}

.card-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.card-tip {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.card-hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.card-tag {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 32rpx;
  letter-spacing: 4rpx;
}

.card-tag.truth {
  background: linear-gradient(135deg, #FF8FA8 0%, #FF6B8A 100%);
}

.card-tag.dare {
  background: linear-gradient(135deg, #FF9F3F 0%, #FF7A3F 100%);
}

.card-text {
  font-size: 38rpx;
  font-weight: 500;
  line-height: 1.5;
  color: var(--color-text);
  word-break: break-word;
}

.card-id {
  position: absolute;
  bottom: 24rpx;
  right: 32rpx;
  font-size: 20rpx;
  color: var(--color-text-muted);
  opacity: 0.5;
}

/* 操作按钮 */
.action-row {
  display: flex;
  margin-bottom: 32rpx;
}

.action-row.two {
  gap: 24rpx;
}

.action-row.two .big-btn {
  flex: 1;
}

.action-row.stack {
  flex-direction: column;
  gap: 20rpx;
}

.big-btn {
  border-radius: 60rpx;
  padding: 32rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.25);
  line-height: 1;
}

.big-btn::after {
  border: none;
}

.big-btn.truth {
  background: linear-gradient(135deg, #FFB6CE 0%, #FF8FA8 100%);
  flex-direction: column;
  gap: 6rpx;
  padding: 36rpx 0;
}

.big-btn.dare {
  background: linear-gradient(135deg, #FFC9A3 0%, #FF9F3F 100%);
  flex-direction: column;
  gap: 6rpx;
  padding: 36rpx 0;
}

.btn-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.btn-label {
  font-size: 32rpx;
  font-weight: 700;
}

.big-btn.done {
  background: linear-gradient(135deg, #6FE3CC 0%, #4ECDC4 100%);
}

.big-btn.reject {
  background: linear-gradient(135deg, #FFB6CE 0%, #FF7A7A 100%);
}

.big-btn[disabled] {
  opacity: 0.55;
}

.aux-row {
  text-align: center;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.aux-link {
  color: var(--color-primary);
}

.aux-divider {
  margin: 0 20rpx;
  color: var(--color-text-muted);
}

/* 底部统计 */
.footer {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding-top: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
}
