/* pages/games/who-knows/who-knows.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD9C2 0%, #FFE4EC 40%, #FFF0F3 100%);
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}
.loading { text-align: center; color: var(--color-text-muted); padding: 240rpx 0; }

/* idle */
.hero { text-align: center; padding: 60rpx 0 40rpx; }
.hero-emoji { font-size: 120rpx; margin-bottom: 16rpx; }
.hero-title { font-size: 48rpx; font-weight: 700; color: var(--color-text); margin-bottom: 16rpx; }
.hero-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.7;
  white-space: pre-line;
}

.last-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.1);
}
.last-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
  text-align: center;
}
.last-line { display: flex; justify-content: space-around; }
.last-col { text-align: center; }
.last-col-label { font-size: 22rpx; color: var(--color-text-muted); }
.last-col-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.start-btn { width: 80%; margin: 0 auto; }

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA8 100%);
  color: #fff; font-size: 32rpx; font-weight: 700;
  border-radius: 60rpx; padding: 28rpx 0; border: none;
  box-shadow: 0 10rpx 28rpx rgba(255, 107, 138, 0.3);
}
.btn-primary::after { border: none; }
.btn-primary[disabled] { background: #F5C5D1; box-shadow: none; }

/* answering */
.progress-bar {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B8A, #FF8FA8);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
.progress-text {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 24rpx;
}

.q-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.12);
  margin-bottom: 32rpx;
}
.q-role {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  background: #FFE4EC;
  color: var(--color-primary);
  font-weight: 700;
  margin-bottom: 16rpx;
}
.q-num {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 700;
  margin-bottom: 4rpx;
}
.q-text {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 28rpx;
}
.options { display: flex; flex-direction: column; gap: 14rpx; }
.option {
  background: #FFF5F7;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 3rpx solid transparent;
}
.option-active {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFD1DC 100%);
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.2);
}
.option-letter {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fff;
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid var(--color-primary-soft);
}
.option-active .option-letter {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}
.option-text { flex: 1; font-size: 28rpx; color: var(--color-text); }

.nav-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.nav-btn {
  flex: 1;
  background: #fff;
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 18rpx 0;
  border: 2rpx solid var(--color-primary-soft);
  line-height: 1;
}
.nav-btn::after { border: none; }
.nav-btn[disabled] { color: var(--color-text-muted); border-color: var(--color-border); }
.nav-btn.submit {
  background: linear-gradient(135deg, #FF6B8A, #FF8FA8);
  color: #fff;
  border: none;
}
.nav-btn.submit[disabled] { background: #F5C5D1; }

.dots {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.dot {
  width: 22rpx; height: 22rpx; border-radius: 50%;
  background: #fff; border: 2rpx solid var(--color-border);
}
.dot-done { background: var(--color-primary-soft); border-color: var(--color-primary-soft); }
.dot-current {
  background: var(--color-primary);
  border-color: var(--color-primary);
  transform: scale(1.25);
}

.cancel-link {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  text-decoration: underline;
}

/* waiting */
.waiting { text-align: center; padding: 120rpx 32rpx; }
.waiting-emoji { font-size: 160rpx; animation: bounce 1.2s ease-in-out infinite; }
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
.waiting-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin: 24rpx 0 12rpx;
}
.waiting-desc { font-size: 26rpx; color: var(--color-text-muted); margin-bottom: 48rpx; }
.refresh-btn { width: 60%; margin: 0 auto 24rpx; }

/* result */
.result-hero {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F7 100%);
  border-radius: 40rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 138, 0.12);
}
.winner-tag {
  display: inline-block;
  font-size: 30rpx;
  font-weight: 700;
  padding: 14rpx 36rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #FF6B8A, #FF8FA8);
  color: #fff;
  margin-bottom: 24rpx;
}
.score-pair { display: flex; justify-content: space-around; }
.score-block { text-align: center; flex: 1; }
.score-label { font-size: 24rpx; color: var(--color-text-muted); margin-bottom: 8rpx; }
.score-big {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}
.score-small {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
}
.score-reward {
  font-size: 22rpx;
  color: #4ECDC4;
  font-weight: 600;
  margin-top: 8rpx;
}

.detail-list { margin-bottom: 40rpx; }
.detail-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}
.detail-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 8rpx solid transparent;
}
.detail-item.match { border-left-color: #4ECDC4; }
.detail-item.miss { border-left-color: #FFB6CE; }
.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.detail-role {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-primary);
  background: #FFE4EC;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}
.detail-flag { font-size: 22rpx; font-weight: 600; }
.detail-item.match .detail-flag { color: #4ECDC4; }
.detail-item.miss .detail-flag { color: var(--color-primary); }
.detail-q {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}
.detail-ans { font-size: 24rpx; line-height: 1.6; }
.ans-line { display: flex; gap: 8rpx; }
.ans-who { color: var(--color-text-muted); flex-shrink: 0; }
.ans-opt { color: var(--color-text); }

.again-btn { width: 80%; margin: 0 auto; }
