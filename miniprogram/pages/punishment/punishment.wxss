/* pages/punishment/punishment.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD1DC 0%, #FFB6CE 50%, #FF9F87 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 48rpx;
  line-height: 1.2;
}

.title .sp {
  height: 8rpx;
}

.content-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 60rpx;
}

/* 左侧危险区 */
.danger-label {
  width: 200rpx;
  background: linear-gradient(180deg, #FF9F87 0%, #FF7A7A 100%);
  border-radius: 32rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 122, 0.3);
}

.danger-tag {
  background: #fff;
  color: #FF7A7A;
  font-size: 24rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 16rpx;
}

.danger-big {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 20rpx;
}

.danger-big .dsp {
  height: 4rpx;
}

.danger-desc {
  font-size: 22rpx;
  line-height: 1.4;
  opacity: 0.95;
}

/* 右侧等级 */
.levels-col {
  flex: 1;
}

.level-row {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.level-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #FFE4A0, #FF9F3F);
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 63, 0.4);
}

.level-circle.light {
  background: radial-gradient(circle at 30% 30%, #FFE4A0, #FFB07C);
}

.level-circle.medium {
  background: radial-gradient(circle at 30% 30%, #FFD08A, #FF8F3F);
}

.level-circle.severe {
  background: radial-gradient(circle at 30% 30%, #FFB57C, #FF7A3F);
}

.level-names {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.level-name {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.punish-icons {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.punish-item {
  flex: 1;
  display: flex;
  justify-content: center;
}

.punish-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.punish-labels {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
}

.punish-label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text);
  line-height: 1.3;
}

/* 进度条 */
.progress-wrap {
  margin-bottom: 60rpx;
}

.progress-bar {
  height: 28rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFB07C 0%, #FF7A3F 100%);
  border-radius: 14rpx;
}

.progress-label {
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text);
}

/* 接受惩罚按钮 */
.accept-btn {
  background: linear-gradient(135deg, #FF7A7A 0%, #FF5C5C 100%);
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  border-radius: 80rpx;
  padding: 32rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(255, 90, 90, 0.4);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.accept-btn::after {
  border: none;
}

.btn-heart {
  color: #FFD1DC;
  font-size: 40rpx;
}
